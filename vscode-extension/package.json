{
  "name": "evecosys-linear-helper",
  "displayName": "EVEcosys Linear Helper",
  "publisher": "your-publisher",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onCommand:extension.requestLinearSession"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "@linear/sdk": "^86.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "extension.requestLinearSession",
        "title": "Request Linear Session"
      }
    ]
  }
}
