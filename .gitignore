# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (all workspaces)
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
**/coverage
e2e/.auth/
e2e/reports/
playwright-report/
test-results/

# next.js
**/.next/
**/out/

# vscode extension artifacts
vscode-extension/node_modules/
vscode-extension/out/

# build outputs
/dist/*
!/dist/tokens
*/dist
**/build
**/storybook-static

# misc
.DS_Store
*.pem
.planning/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# supabase
supabase/.temp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
